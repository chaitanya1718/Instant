# GROQ_API_KEY: Required for Groq AI API calls.
GROQ_API_KEY=your_groq_api_key_here

# GROQ_MODEL: Optional. Defaults to llama-3.1-8b-instant.
GROQ_MODEL=llama-3.1-8b-instant

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Authentication
JWT_SECRET=

# Database
# Note: If your password contains special characters (e.g., @, :, /), 
# they MUST be URL-encoded (e.g., @ becomes %40).
MONGODB_URI=

# App
APP_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3000

# Password reset email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=DailyFlow

# Password reset email (HTTP API provider)
# Set EMAIL_PROVIDER=resend to use Resend instead of SMTP.
EMAIL_PROVIDER=smtp
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=DailyFlow

RESET_TOKEN_EXPIRY_MINUTES=60
RESET_REQUEST_COOLDOWN_SECONDS=60
